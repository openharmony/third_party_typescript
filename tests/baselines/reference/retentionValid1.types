>'source' : "source"

    BYTECODE='bytecode'
>BYTECODE : RetentionPolicy.BYTECODE
>'bytecode' : "bytecode"
}

export @interface Retention {
    policy: RetentionPolicy
>policy : RetentionPolicy
}

